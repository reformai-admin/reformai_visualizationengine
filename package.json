{
  "name": "visualization-engine-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web-sandbox",
    "apps/vis-service"
  ],
  "scripts": {
    "build": "npm run build --workspace=apps/web-sandbox",
    "dev": "concurrently \"npm run dev --workspace=back-reformai\" \"npm run dev --workspace=apps/web-sandbox\"",
    "regression:preflight": "node tests/regression/preflight.mjs",
    "regression:preflight:full": "node tests/regression/preflight.mjs --config tests/regression/config.full_matrix.yaml --strict"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
